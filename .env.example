# Application
NODE_ENV=development
PORT=3000

# AI / LLM Integration (Phase 2)
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# File Storage
PDF_UPLOAD_DIR=./data/uploads
OUTPUT_DIR=./outputs

# Logging
LOG_LEVEL=info

# Phase 6 — LLM-assisted extraction
# When true, the LLM-assisted extraction stage runs first; the deterministic
# parser is always the fallback. Defaults to false (deterministic-only).
LLM_EXTRACTION_ENABLED=false
# Minimum model confidence (0..1) for admitting a lab_result as a finding.
LLM_CONFIDENCE_THRESHOLD=0.5
