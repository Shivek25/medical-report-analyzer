# Application
NODE_ENV=development
PORT=3000

# AI / LLM Integration (Phase 2)
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# File Storage
PDF_UPLOAD_DIR=./data/uploads
OUTPUT_DIR=./outputs

# Logging
LOG_LEVEL=info

# Phase 6/7 — LLM-assisted extraction
# When true, the Ollama-backed extraction stage (qwen3:8b) runs first.
# The deterministic parser is always the fallback. Defaults to false.
LLM_EXTRACTION_ENABLED=false
# Minimum model confidence (0..1) for admitting a lab_result as a finding.
LLM_CONFIDENCE_THRESHOLD=0.5

# Phase 7 — Ollama adapter (local-only, no paid API, no external network)
# Base URL of the local Ollama server. Default works if Ollama is running
# on the same machine with default settings.
OLLAMA_BASE_URL=http://localhost:11434
# Extraction model tag. qwen3:8b is the default. Do not use medgemma:4b
# here — it is reserved for a later medical interpretation/summary phase.
OLLAMA_MODEL=qwen3:8b
# HTTP timeout (ms) for Ollama generate calls. The health check uses a
# shorter fixed timeout (5 s) regardless of this value.
OLLAMA_TIMEOUT_MS=60000
